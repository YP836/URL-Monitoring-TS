# SMTP settings for alert email notifications.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# For Gmail: enable 2-Step Verification, then create an "App Password"
# (Google Account -> Security -> App passwords) and paste the 16-char value below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
